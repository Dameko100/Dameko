# ============================================================
# Dameko News Bot - Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# ---- REQUIRED ----

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram Chat ID where alerts will be sent
# For a personal chat: send /start to @userinfobot to get your ID
# For a group/channel: use a negative number like -1001234567890
TELEGRAM_CHAT_ID=123456789

# ---- OPTIONAL (but recommended for more news coverage) ----

# NewsAPI key - get a free key at https://newsapi.org/register
# Without this key the bot uses RSS feeds only (still works great)
NEWSAPI_KEY=

# ---- SCHEDULER ----

# How often to check for new news (in minutes, default: 10)
POLL_INTERVAL_MINUTES=10

# Hour (UTC) to send the daily trending Polymarket digest (0-23, default: 8)
DIGEST_HOUR_UTC=8

# ---- FILTERING ----

# Minimum article importance score to send a notification (0.0-1.0, default: 0.2)
# Lower = more notifications, Higher = only the most impactful news
MIN_IMPORTANCE_SCORE=0.2

# Minimum Polymarket market liquidity in USD to include in alerts (default: 100)
MIN_MARKET_LIQUIDITY=100

# Max number of Polymarket markets to show per news alert (default: 4)
MAX_MARKETS_PER_ALERT=4

# Days to keep seen-article records before cleanup (default: 7)
SEEN_ARTICLES_TTL_DAYS=7
